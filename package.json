{
  "name": "ollama-status",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:docker": "docker down -v; docker compose build --no-cache; docker compose up -d",
    "build": "tsc -b && vite build",
    "format": "npx prettier --write ./src/",
    "check": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:postgres": "node scripts/test-postgres.mjs",
    "spike": "node scripts/spike.mjs",
    "quota:test": "node scripts/quota-test.mjs",
    "monitor:run": "node scripts/run-monitor.mjs",
    "lint": "eslint .",
    "dev:node": "node --env-file=.env --watch src/node/server.ts",
    "start:web": "node src/node/server.ts",
    "start:runner": "node src/node/runner.ts",
    "migrate:node": "node scripts/migrate-node.mjs"
  },
  "dependencies": {
    "node-cron": "^4.6.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "srvx": "^0.11.22"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^3.2.4"
  }
}
