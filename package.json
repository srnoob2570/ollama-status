{
  "name": "ollama-status",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit -p tsconfig.worker.json && tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "spike": "node scripts/spike.mjs",
    "quota:test": "node scripts/quota-test.mjs",
    "lint": "eslint .",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "deploy:production": "npm run build && wrangler deploy --env production",
    "format": "npx prettier --write ./src/"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "vite": "^8.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.24.3"
  }
}
