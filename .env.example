# Local development with `docker compose up --build migrate web runner`.
# A local PostgreSQL must exist on port 5432. In Docker Desktop,
# host.docker.internal allows containers to reach the host machine.
# When using docker compose, docker-compose.override.yml replaces this URL with postgres:5432.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ollama_status
POSTGRES_DB=ollama_status
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

PORT=3000
RUNNER_HEALTH_PORT=3001
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_API_KEY_FREE=
OLLAMA_API_KEY_PAID=
OLLAMA_MAX_TOKENS=8

FREE_CHECK_INTERVAL_MINUTES=5
PAID_CHECK_INTERVAL_MINUTES=10
FREE_PROBE_CONCURRENCY=1
PAID_PROBE_CONCURRENCY=6
PROBE_DELAY_MIN_MS=0
PROBE_DELAY_MAX_MS=5000
EXCLUDED_MODELS=

# Local value to sign confirmations and manual runs.
# openssl rand -hex 32
CONFIRMATION_HMAC_SECRET= 
CONFIRMATION_CALLBACK_URL=
GITHUB_REPOSITORY=
GITHUB_ACTIONS_TOKEN=
ENVIRONMENT=development

# Remote tunnel token managed by Cloudflare Zero Trust.
TUNNEL_TOKEN=
