{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ollama-status",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-10",
  "workers_dev": false,
  "assets": { "directory": "./dist", "binding": "ASSETS", "run_worker_first": true, "not_found_handling": "single-page-application" },
  "triggers": { "crons": ["*/5 * * * *"] },
  "d1_databases": [{ "binding": "DB", "database_name": "ollama-status", "database_id": "REPLACE_WITH_D1_ID" }],
  "vars": { "OLLAMA_BASE_URL": "https://ollama.com/api", "OLLAMA_MAX_TOKENS": "8", "PROBE_CONCURRENCY": "1", "PROBE_DELAY_MIN_MS": "0", "PROBE_DELAY_MAX_MS": "5000", "EXCLUDED_MODELS": "" },
  "env": {
    "staging": {
      "name": "ollama-status-staging", "assets": { "directory": "./dist", "binding": "ASSETS", "run_worker_first": true, "not_found_handling": "single-page-application" },
      "triggers": { "crons": ["*/5 * * * *"] },
      "d1_databases": [{ "binding": "DB", "database_name": "ollama-status-staging", "database_id": "b8e3a94e-7cc2-404b-b76a-e6bef5181b77" }],
      "vars": { "ENVIRONMENT": "staging", "OLLAMA_BASE_URL": "https://ollama.com/api", "OLLAMA_MAX_TOKENS": "8", "PROBE_CONCURRENCY": "1", "PROBE_DELAY_MIN_MS": "0", "PROBE_DELAY_MAX_MS": "5000", "EXCLUDED_MODELS": "" }
    },
    "production": {
      "name": "ollama-status", "assets": { "directory": "./dist", "binding": "ASSETS", "run_worker_first": true, "not_found_handling": "single-page-application" },
      "triggers": { "crons": ["*/5 * * * *"] },
      "d1_databases": [{ "binding": "DB", "database_name": "ollama-status", "database_id": "REPLACE_WITH_PRODUCTION_D1_ID" }],
      "vars": { "ENVIRONMENT": "production", "OLLAMA_BASE_URL": "https://ollama.com/api", "OLLAMA_MAX_TOKENS": "8", "PROBE_CONCURRENCY": "1", "PROBE_DELAY_MIN_MS": "0", "PROBE_DELAY_MAX_MS": "5000", "EXCLUDED_MODELS": "" }
    }
  }
}
