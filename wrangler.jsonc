{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "ollama-status",
    "main": "src/worker/index.ts",
    "compatibility_date": "2026-07-10",
    "workers_dev": false,
    "assets": {
        "directory": "./dist",
        "binding": "ASSETS",
        "run_worker_first": true,
        "not_found_handling": "single-page-application",
    },
    "triggers": {
        "crons": [
            "*/5 * * * *"
        ],
    },
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "ollama-status",
            "database_id": "REPLACE_WITH_D1_ID",
        },
    ],
    "env": {
        "staging": {
            "name": "ollama-status-staging",
            "assets": {
                "directory": "./dist",
                "binding": "ASSETS",
                "run_worker_first": true,
                "not_found_handling": "single-page-application",
            },
            "triggers": {
                "crons": [
                    "*/5 * * * *"
                ],
            },
            "d1_databases": [
                {
                    "binding": "DB",
                    "database_name": "ollama-status-staging",
                    "database_id": "98b85e7c-d2af-4910-8d9e-d6bdbf2ecee4",
                },
            ],
            "vars": {
                "ENVIRONMENT": "staging",
                "OLLAMA_BASE_URL": "https://ollama.com/api",
                "OLLAMA_MAX_TOKENS": "2",
                "FREE_CHECK_INTERVAL_MINUTES": "5",
                "PAID_CHECK_INTERVAL_MINUTES": "10",
                "PROBE_CONCURRENCY": "6",
                "PROBE_DELAY_MIN_MS": "0",
                "PROBE_DELAY_MAX_MS": "5000",
                "CONFIRMATION_CALLBACK_URL": "https://ollama-status-staging.srnoob.dev/api/internal/confirmation",
                "GITHUB_REPOSITORY": "srnoob2570/ollama-status",
            },
        },
        "production": {
            "name": "ollama-status",
            "assets": {
                "directory": "./dist",
                "binding": "ASSETS",
                "run_worker_first": true,
                "not_found_handling": "single-page-application",
            },
            "triggers": {
                "crons": [
                    "*/5 * * * *"
                ],
            },
            "d1_databases": [
                {
                    "binding": "DB",
                    "database_name": "ollama-status",
                    "database_id": "55d84318-9b85-4a1e-8007-c57af9f27880",
                },
            ],
            "vars": {
                "ENVIRONMENT": "production",
                "OLLAMA_BASE_URL": "https://ollama.com/api",
                "OLLAMA_MAX_TOKENS": "2",
                "FREE_CHECK_INTERVAL_MINUTES": "5",
                "PAID_CHECK_INTERVAL_MINUTES": "5",
                "PROBE_CONCURRENCY": "6",
                "PROBE_DELAY_MIN_MS": "0",
                "PROBE_DELAY_MAX_MS": "5000",
                "CONFIRMATION_CALLBACK_URL": "https://ollama-status.srnoob.dev/api/internal/confirmation",
                "GITHUB_REPOSITORY": "srnoob2570/ollama-status",
            },
        },
    },
    "observability": {
        "logs": {
            "enabled": true,
            "invocation_logs": true,
        },
    },
}
