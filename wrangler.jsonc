{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ollama-status",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-10",
  "workers_dev": false,
  "assets": { "directory": "./dist", "binding": "ASSETS", "run_worker_first": true, "not_found_handling": "single-page-application" },
  "triggers": { "crons": ["*/5 * * * *"] },
  "d1_databases": [{ "binding": "DB", "database_name": "ollama-status", "database_id": "REPLACE_WITH_D1_ID" }],
  "queues": {
    "producers": [{ "binding": "INCIDENT_EVENTS", "queue": "ollama-status-incidents" }],
    "consumers": [{ "queue": "ollama-status-incidents", "max_batch_size": 10, "max_retries": 3, "max_concurrency": 1 }]
  },
  "vars": { "OLLAMA_BASE_URL": "https://ollama.com/api", "OLLAMA_MAX_TOKENS": "8", "ACCESS_TEAM_DOMAIN": "", "ACCESS_AUD": "", "EXCLUDED_MODELS": "" },
  "env": {
    "staging": {
      "name": "ollama-status-staging", "assets": { "directory": "./dist", "binding": "ASSETS", "run_worker_first": true, "not_found_handling": "single-page-application" },
      "triggers": { "crons": ["*/5 * * * *"] },
      "d1_databases": [{ "binding": "DB", "database_name": "ollama-status-staging", "database_id": "REPLACE_WITH_STAGING_D1_ID" }],
      "queues": { "producers": [{ "binding": "INCIDENT_EVENTS", "queue": "ollama-status-incidents-staging" }], "consumers": [{ "queue": "ollama-status-incidents-staging", "max_batch_size": 10, "max_retries": 3, "max_concurrency": 1 }] },
      "vars": { "ENVIRONMENT": "staging", "OLLAMA_BASE_URL": "https://ollama.com/api", "OLLAMA_MAX_TOKENS": "8", "ACCESS_TEAM_DOMAIN": "", "ACCESS_AUD": "", "EXCLUDED_MODELS": "" }
    },
    "production": {
      "name": "ollama-status", "assets": { "directory": "./dist", "binding": "ASSETS", "run_worker_first": true, "not_found_handling": "single-page-application" },
      "triggers": { "crons": ["*/5 * * * *"] },
      "d1_databases": [{ "binding": "DB", "database_name": "ollama-status", "database_id": "REPLACE_WITH_PRODUCTION_D1_ID" }],
      "queues": { "producers": [{ "binding": "INCIDENT_EVENTS", "queue": "ollama-status-incidents" }], "consumers": [{ "queue": "ollama-status-incidents", "max_batch_size": 10, "max_retries": 3, "max_concurrency": 1 }] },
      "vars": { "ENVIRONMENT": "production", "OLLAMA_BASE_URL": "https://ollama.com/api", "OLLAMA_MAX_TOKENS": "8", "ACCESS_TEAM_DOMAIN": "", "ACCESS_AUD": "", "EXCLUDED_MODELS": "" }
    }
  }
}
